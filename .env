# Налаштування PostgreSQL контейнера
POSTGRES_USER=k2_user
POSTGRES_PASSWORD=k2_password
POSTGRES_DB=k2_erp_orders
POSTGRES_PORT=5432

# URL для підключення Flask додатка до БД всередині докер-мережі
DATABASE_URL=postgresql://k2_user:k2_password@db:5432/k2_erp_orders

# Налаштування Flask
FLASK_APP=app:create_app
FLASK_DEBUG=1